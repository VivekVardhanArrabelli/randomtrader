# Alpaca (paper trading)
ALPACA_API_KEY=your_alpaca_key
ALPACA_API_SECRET=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Polygon
POLYGON_API_KEY=your_polygon_key
POLYGON_BASE_URL=https://api.polygon.io

# Theta Data (historical options backtests)
THETA_BASE_URL=http://127.0.0.1:25510
HISTORICAL_OPTIONS_PROVIDER=theta

# OpenAI (default LLM path)
OPENAI_API_KEY=your_openai_key
LLM_MODEL=gpt-5.4
MAX_CONSECUTIVE_LLM_ERROR_CYCLES=3

# Anthropic (optional alternate provider)
ANTHROPIC_API_KEY=your_anthropic_key

# Risk rails (optional live/paper overrides; defaults live in ai_trader/config.py)
# The code defaults are aggressive (40% of equity per trade). For any real-money
# run, set these to something far more conservative, e.g.:
# MAX_RISK_PER_TRADE=0.05
# MAX_TOTAL_EXPOSURE=0.25
# DAILY_LOSS_LIMIT=0.05
# MAX_OPEN_POSITIONS=5
